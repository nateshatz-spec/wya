{
  "name": "wya-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create wya-user-data",
    "db:migrate": "wrangler d1 execute wya-user-data --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute wya-user-data --local --file=./schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.84.1"
  },
  "dependencies": {
    "@cloudflare/workerd-darwin-arm64": "^1.20260422.1"
  }
}
